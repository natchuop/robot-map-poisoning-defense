# Optional Docker Compose overrides.
#
# Copy to .env only if your machine needs different values. Docker Compose
# automatically reads .env from the repo root.

# Published Webots bridge port on the host.
RMPD_BRIDGE_PORT=5005

# Host interface for the bridge port. Use 0.0.0.0 only when another machine
# must connect to this laptop.
RMPD_BRIDGE_BIND=127.0.0.1

# Workspace path inside the container.
RMPD_CONTAINER_WORKSPACE=/workspace

# Local image tag used by docker compose build/up.
RMPD_IMAGE=robot-map-poisoning-defense:local

# Set false only as a temporary fallback when ROS package mirrors are unhealthy.
# Minimal images can build but will not run Nav2, RViz, or Webots ROS packages.
RMPD_INSTALL_FULL_STACK=true

# WSLg-only GUI bind mounts used by docker-compose.wslg.yml.
RMPD_X11_SOCKET=/tmp/.X11-unix
RMPD_WSLG_RUNTIME=/mnt/wslg
RMPD_XDG_RUNTIME_DIR=/mnt/wslg/runtime-dir
RMPD_QT_QPA_PLATFORM=wayland;xcb
RMPD_QT_XCB_GL_INTEGRATION=none
RMPD_LIBGL_ALWAYS_SOFTWARE=1
RMPD_XQUARTZ_DISPLAY=host.docker.internal:0

# quick_test.sh uses auto by default: launch RViz when a Docker-visible display
# is detected, otherwise verify that rviz2 is installed and skip GUI startup.
RMPD_QUICK_TEST_RVIZ=auto
